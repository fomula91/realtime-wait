{
  "name": "@realtime-wait/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute realtime-wait --local --file=../../db/schema.sql",
    "db:seed": "wrangler d1 execute realtime-wait --local --file=../../db/seed.sql",
    "db:reset": "pnpm db:init && pnpm db:seed"
  },
  "dependencies": {
    "@realtime-wait/shared": "workspace:*",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.99.0"
  }
}
